{
  "start": {
    "state_id": "start",
    "type": "input",
    "message": "Excellent! Before we dive in — what's your name?",
    "capture": "name",
    "next": "ask_email",
    "fallback": "ask_email"
  },
  "ask_email": {
    "state_id": "ask_email",
    "type": "input",
    "message": "Thanks {{name}}! What's your business email address?",
    "capture": "email",
    "next": "choose_topic",
    "fallback": "choose_topic"
  },
  "choose_topic": {
    "state_id": "choose_topic",
    "type": "choice",
    "message": "What would you like to know about AI avatar videos for your accounting practice?",
    "options": [
      "Why would a CPA use avatar videos?",
      "Is it authentic?",
      "What does it cost?",
      "Ethics and compliance?",
      "I'm too busy during tax season",
      "My clients won't watch videos",
      "I would like to get in touch"
    ],
    "transitions": {
      "Why would a CPA use avatar videos?": "llm_chat",
      "Is it authentic?": "llm_chat",
      "What does it cost?": "llm_chat",
      "Ethics and compliance?": "llm_chat",
      "I'm too busy during tax season": "llm_chat",
      "My clients won't watch videos": "llm_chat",
      "I would like to get in touch": "end"
    },
    "option_config": {
      "Why would a CPA use avatar videos?": { "mode": "llm", "llm_prompt": "", "next": "llm_chat" },
      "Is it authentic?": { "mode": "llm", "llm_prompt": "", "next": "llm_chat" },
      "What does it cost?": { "mode": "llm", "llm_prompt": "", "next": "llm_chat" },
      "Ethics and compliance?": { "mode": "llm", "llm_prompt": "", "next": "llm_chat" },
      "I'm too busy during tax season": { "mode": "llm", "llm_prompt": "", "next": "llm_chat" },
      "My clients won't watch videos": { "mode": "llm", "llm_prompt": "", "next": "llm_chat" },
      "I would like to get in touch": { "mode": "transition" }
    },
    "fallback": "handle_objection"
  },
  "llm_chat": {
    "state_id": "llm_chat",
    "type": "llm",
    "prompt_template": "",
    "next": "llm_chat",
    "options": ["I'd like to get in touch"],
    "transitions": {
      "I'd like to get in touch": "end"
    },
    "fallback": "end"
  },
  "end": {
    "state_id": "end",
    "type": "end",
    "message": "Thank you {{name}}! A member of our team will reach out to {{email}} within 24 hours to show you exactly how Evidence Based Advisor Marketing can help your practice stand out.",
    "user_type": "cpa"
  },
  "handle_objection": {
    "state_id": "handle_objection",
    "type": "llm",
    "prompt_template": "A CPA said: '{{input}}'.\nRespond warmly and professionally, address their concern, and gently guide them back to the conversation. Keep it to 2–3 sentences.",
    "next": "return_to_previous",
    "fallback": "choose_topic"
  }
}
